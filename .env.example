# Environment Configuration for HafiPortrait Admin Dashboard
# Copy this file to .env.local for local development
# Set these variables in Vercel dashboard for production

# App Configuration
NEXT_PUBLIC_APP_URL=https://hafiportrait.photography
NODE_ENV=production

# Database Configuration
DATABASE_URL=your_database_url_here
DATABASE_HOST=your_database_host
DATABASE_PORT=5432
DATABASE_NAME=your_database_name
DATABASE_USER=your_database_user
DATABASE_PASSWORD=your_database_password

# Authentication
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# CORS Configuration
ALLOWED_ORIGINS=https://hafiportrait.photography,https://www.hafiportrait.photography,https://hafiportrait.vercel.app

# API Configuration
DSLR_API_BASE_URL=https://hafiportrait.photography
NEXT_PUBLIC_API_BASE_URL=https://hafiportrait.photography

# Storage Configuration (if using cloud storage)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_ENDPOINT=your_r2_endpoint

# Email Configuration (if using email services)
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Monitoring and Analytics  
NEXT_PUBLIC_GA_ID=your_google_analytics_id
SENTRY_DSN=your_sentry_dsn

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudflare R2 Storage (Optional - for file storage)
CLOUDFLARE_R2_ACCOUNT_ID=your_cloudflare_r2_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id  
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=your_r2_bucket_name

# Google Drive Storage (Optional - for backup)
GOOGLE_DRIVE_CLIENT_ID=your_google_drive_client_id
GOOGLE_DRIVE_CLIENT_SECRET=your_google_drive_client_secret
GOOGLE_DRIVE_REFRESH_TOKEN=your_google_drive_refresh_token

# WebSocket Configuration
WEBSOCKET_PORT=3001
SOCKETIO_PORT=3003

# Feature Flags
ENABLE_WEBSOCKET=true
ENABLE_REAL_TIME_UPDATES=true
ENABLE_FILE_UPLOAD=true

# Optional: Disable specific features in development
# DISABLE_SESSION_LOGGING=true
